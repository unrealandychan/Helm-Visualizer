# LLM Chatbot — environment variables
# Copy this file to .env.local and fill in your values, then restart the dev server.

# Required: API key for OpenAI (or any compatible provider)
OPENAI_API_KEY=sk-...

# Optional: base URL for an OpenAI-compatible API endpoint
# Defaults to https://api.openai.com when not set.
# Use this to point at Azure OpenAI, Groq, Ollama, or any other compatible backend.
# OPENAI_BASE_URL=https://api.openai.com

# Optional: model name to use for the chatbot (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
